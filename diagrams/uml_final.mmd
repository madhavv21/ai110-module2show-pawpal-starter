classDiagram
    %% PawPal+ class diagram
    %% Owner manages multiple Pets; each Pet owns its own Tasks;
    %% Scheduler is the stateless "brain" that aggregates tasks across pets and builds a plan,
    %% either strictly by priority (greedy) or by maximizing total priority value (knapsack).
    %% Priority is a plain string ("low" | "medium" | "high"), matching app.py's selectbox.
    %% recurring is a plain string ("daily" | "weekly" | "monthly") or None for one-off tasks.

    class Task {
        -str task_id
        -str pet_id
        -str title
        -int duration_minutes
        -str priority
        -str category
        -str recurring
        -time scheduled_time
        -date scheduled_date
        -bool done
        +get_title() str
        +set_title(title str) None
        +get_duration() int
        +set_duration(minutes int) None
        +get_priority() str
        +set_priority(priority str) None
        +get_category() str
        +set_category(category str) None
        +is_recurring() bool
        +get_recurrence_frequency() str
        +set_recurring(recurring str) None
        +get_scheduled_time() time
        +set_scheduled_time(scheduled_time time) None
        +get_scheduled_date() date
        +set_scheduled_date(scheduled_date date) None
        +is_done() bool
        +mark_done() None
        +next_occurrence() Task
    }

    class Pet {
        -str pet_id
        -str name
        -str species
        -str breed
        -int age
        -list~Task~ tasks
        +get_name() str
        +set_name(name str) None
        +get_species() str
        +describe() str
        +add_task(task Task) None
        +edit_task(task_id str, changes dict) None
        +complete_task(task_id str) None
        +remove_task(task_id str) None
        +get_tasks() list~Task~
    }

    class Scheduler {
        -bool optimize_for_fit
        -list~Task~ planned
        -list~Task~ skipped
        -dict skip_shortfalls
        +get_all_tasks(pets list~Pet~) list~Task~
        +sort_by_priority(tasks list~Task~) list~Task~
        +sort_by_time(tasks list~Task~) list~Task~
        +find_time_conflicts(pets list~Pet~) list
        +explain_conflicts(pets list~Pet~) list~str~
        +filter_tasks(pets list~Pet~, done bool, pet_name str) list~Task~
        +generate_plan(pets list~Pet~, minutes_available int) list~Task~
        +explain_plan() str
        -_fit_greedy(tasks list~Task~, minutes_available int) tuple
        -_fit_knapsack(tasks list~Task~, minutes_available int) tuple
        -_explain_skip(task Task) str
    }

    class Owner {
        -str name
        -int age
        -date dob
        -int minutes_available
        -list~Pet~ pets
        -Scheduler scheduler
        +get_name() str
        +set_name(name str) None
        +add_pet(pet Pet) None
        +remove_pet(pet_id str) None
        +get_pets() list~Pet~
        +get_minutes_available() int
        +set_minutes_available(minutes int) None
        +set_optimize_for_fit(optimize_for_fit bool) None
        +get_optimize_for_fit() bool
        +filter_tasks(done bool, pet_name str) list~Task~
        +find_time_conflicts() list
        +explain_conflicts() list~str~
        +generate_plan() list~Task~
        +explain_plan() str
    }

    %% Relationships
    Owner "1" o-- "0..*" Pet : owns
    Owner "1" *-- "1" Scheduler : uses
    Pet "1" o-- "0..*" Task : has
    Scheduler ..> Task : reads/sorts/plans
    Pet ..> Task : completes and clones next occurrence
